// format: RAIZ_DEFINE_TOKEN(VariantName, StringSymbol)

// Binary operators:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_PLUS,    "+")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_MINUS,   "-")
// NOTE: '*' is dereference operator when in an unary expression
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_STAR,    "*")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_SLASH,   "/")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_PERCENT, "%")

// Grouping operators:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_OPEN_PARENTHESES,   "(")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_CLOSE_PARENTHESES,  ")")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_OPEN_BRACKETS,      "[")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_CLOSE_BRACKETS,     "]")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_OPEN_CURLY_BRACES,  "{")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_CLOSE_CURLY_BRACES, "}")

// Punctuation symbols:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_DOT,    ".")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_COMMA,  ",")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_COLLON, ":")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_BANG,   "!")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_WHAT,   "?")

// Comparison operators:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_EQUAL,            "==")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_NOT_EQUAL,        "!=")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_GREATER_THAN,      ">")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_LESS_THAN,         "<")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_GREATER_OR_EQUAL, ">=")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_LESS_OR_EQUAL,    "<=")

// Special symbols:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_ASSIGN,    "=")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_AT,        "@")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_HASH,      "#")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_DOLLAR,    "$")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_AMPERSAND, "&")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_PIPE,      "|")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_HAT,       "^")

// Arrows:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_FAT_ARROW,       "=>")

// Doubled symbol tokens:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_DOUBLE_PIPE,      "||")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_DOUBLE_AMPERSAND, "&&")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_DOUBLE_GREATER,   ">>")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_DOUBLE_LESS,      "<<")

// Literals:
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_LITERAL_INT,     "<number literal>")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_LITERAL_CHAR, "<character literal>")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_LITERAL_STRING,  "<string literal>")

// Keywords (alphabetical order please):
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_AS, "as")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_DO, "do")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_OR, "or")

RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_FOR, "for")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_FUN, "fun")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_LET, "let")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_NOT, "not")
// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_TAB, "tab")
// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_USE, "use")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_VAL, "val")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_VAR, "var")

RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_ELSE, "else")
// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_MATH, "math")
// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_SELF, "self")

// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_EVENT, "event")
// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_MACRO, "macro")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_MATCH, "match")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_SHELL, "shell")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_WHILE, "while")

// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_ONEVENT, "onevent")
// RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_KWD_TRIGGER, "trigger")

RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_IDENTIFIER, "<identifier>")
RAIZ_DEFINE_TOKEN(RAIZ_TOKEN_TYPE_IDENTIFIER, "<type>")
